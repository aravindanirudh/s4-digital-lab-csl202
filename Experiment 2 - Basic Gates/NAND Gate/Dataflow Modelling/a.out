#! /usr/bin/vvp
:ivl_version "10.3 (stable)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision + 0;
:vpi_module "system";
:vpi_module "vhdl_sys";
:vpi_module "v2005_math";
:vpi_module "va_math";
S_0x55f880d15820 .scope module, "testbencha1" "testbencha1" 2 1;
 .timescale 0 0;
v0x55f880d25970_0 .var "a", 0 0;
v0x55f880d25a40_0 .var "b", 0 0;
v0x55f880d25b10_0 .net "c", 0 0, L_0x55f880d25c10;  1 drivers
S_0x55f880d159a0 .scope module, "uut" "nandgate1" 2 4, 3 1 0, S_0x55f880d15820;
 .timescale 0 0;
    .port_info 0 /OUTPUT 1 "c"
    .port_info 1 /INPUT 1 "a"
    .port_info 2 /INPUT 1 "b"
L_0x55f880d25c10 .functor NAND 1, v0x55f880d25970_0, v0x55f880d25a40_0, C4<1>, C4<1>;
v0x55f880ce0080_0 .net "a", 0 0, v0x55f880d25970_0;  1 drivers
v0x55f880d25790_0 .net "b", 0 0, v0x55f880d25a40_0;  1 drivers
v0x55f880d25850_0 .net "c", 0 0, L_0x55f880d25c10;  alias, 1 drivers
    .scope S_0x55f880d15820;
T_0 ;
    %vpi_call 2 6 "$dumpfile", "nandgate1.vcd" {0 0 0};
    %vpi_call 2 7 "$dumpvars" {0 0 0};
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x55f880d25970_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x55f880d25a40_0, 0, 1;
    %delay 10, 0;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x55f880d25970_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x55f880d25a40_0, 0, 1;
    %delay 10, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x55f880d25970_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x55f880d25a40_0, 0, 1;
    %delay 10, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x55f880d25970_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x55f880d25a40_0, 0, 1;
    %delay 10, 0;
    %vpi_call 2 20 "$finish" {0 0 0};
    %end;
    .thread T_0;
