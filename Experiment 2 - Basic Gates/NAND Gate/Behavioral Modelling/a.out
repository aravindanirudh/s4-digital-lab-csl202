#! /usr/bin/vvp
:ivl_version "10.3 (stable)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision + 0;
:vpi_module "system";
:vpi_module "vhdl_sys";
:vpi_module "v2005_math";
:vpi_module "va_math";
S_0x5651c2cfdac0 .scope module, "testbencha1" "testbencha1" 2 1;
 .timescale 0 0;
v0x5651c2d0dd80_0 .var "a", 0 0;
v0x5651c2d0de50_0 .var "b", 0 0;
v0x5651c2d0df20_0 .net "c", 0 0, v0x5651c2d0dc60_0;  1 drivers
S_0x5651c2cfdc40 .scope module, "uut" "nandgate1" 2 4, 3 1 0, S_0x5651c2cfdac0;
 .timescale 0 0;
    .port_info 0 /OUTPUT 1 "c"
    .port_info 1 /INPUT 1 "a"
    .port_info 2 /INPUT 1 "b"
v0x5651c2cc8030_0 .net "a", 0 0, v0x5651c2d0dd80_0;  1 drivers
v0x5651c2d0dba0_0 .net "b", 0 0, v0x5651c2d0de50_0;  1 drivers
v0x5651c2d0dc60_0 .var "c", 0 0;
E_0x5651c2cfe080 .event edge, v0x5651c2d0dba0_0, v0x5651c2cc8030_0;
    .scope S_0x5651c2cfdc40;
T_0 ;
    %wait E_0x5651c2cfe080;
    %load/vec4 v0x5651c2cc8030_0;
    %load/vec4 v0x5651c2d0dba0_0;
    %nand;
    %store/vec4 v0x5651c2d0dc60_0, 0, 1;
    %jmp T_0;
    .thread T_0, $push;
    .scope S_0x5651c2cfdac0;
T_1 ;
    %vpi_call 2 6 "$dumpfile", "nandgate1.vcd" {0 0 0};
    %vpi_call 2 7 "$dumpvars" {0 0 0};
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5651c2d0dd80_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5651c2d0de50_0, 0, 1;
    %delay 10, 0;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5651c2d0dd80_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5651c2d0de50_0, 0, 1;
    %delay 10, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5651c2d0dd80_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5651c2d0de50_0, 0, 1;
    %delay 10, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5651c2d0dd80_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5651c2d0de50_0, 0, 1;
    %delay 10, 0;
    %vpi_call 2 20 "$finish" {0 0 0};
    %end;
    .thread T_1;
# The file index is used to find the file name in the following table.
:file_names 4;
    "N/A";
    "<interactive>";
    "testbencha1.v";
    "nandgate1.v";
