:vpi_module "v2005_math";
:vpi_module "va_math";
S_0x55a0984a3760 .scope module, "testbencha1" "testbencha1" 2 1;
 .timescale 0 0;
v0x55a0984b2010_0 .var "a", 0 0;
v0x55a0984b20b0_0 .net "c", 0 0, v0x55a0984b1ef0_0;  1 drivers
S_0x55a09846e030 .scope module, "uut" "notgate1" 2 4, 3 1 0, S_0x55a0984a3760;
 .timescale 0 0;
    .port_info 0 /OUTPUT 1 "c"
    .port_info 1 /INPUT 1 "a"
v0x55a09846e220_0 .net "a", 0 0, v0x55a0984b2010_0;  1 drivers
v0x55a0984b1ef0_0 .var "c", 0 0;
E_0x55a09846e7b0 .event edge, v0x55a09846e220_0;
    .scope S_0x55a09846e030;
T_0 ;
    %wait E_0x55a09846e7b0;
    %load/vec4 v0x55a09846e220_0;
    %inv;
    %store/vec4 v0x55a0984b1ef0_0, 0, 1;
    %jmp T_0;
    .thread T_0, $push;
    .scope S_0x55a0984a3760;
T_1 ;
    %vpi_call 2 6 "$dumpfile", "notgate1.vcd" {0 0 0};
    %vpi_call 2 7 "$dumpvars" {0 0 0};
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x55a0984b2010_0, 0, 1;
    %delay 10, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x55a0984b2010_0, 0, 1;
    %delay 10, 0;
    %vpi_call 2 12 "$finish" {0 0 0};
    %end;
    .thread T_1;
