#! /usr/bin/vvp
:ivl_version "10.3 (stable)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision + 0;
:vpi_module "system";
:vpi_module "vhdl_sys";
:vpi_module "v2005_math";
:vpi_module "va_math";
S_0x55c9b9130ac0 .scope module, "testbencha1" "testbencha1" 2 1;
 .timescale 0 0;
v0x55c9b9140d40_0 .var "a", 0 0;
v0x55c9b9140e10_0 .var "b", 0 0;
v0x55c9b9140ee0_0 .net "c", 0 0, v0x55c9b9140c20_0;  1 drivers
S_0x55c9b9130c40 .scope module, "uut" "andgate1" 2 4, 3 1 0, S_0x55c9b9130ac0;
 .timescale 0 0;
    .port_info 0 /OUTPUT 1 "c"
    .port_info 1 /INPUT 1 "a"
    .port_info 2 /INPUT 1 "b"
v0x55c9b90fb030_0 .net "a", 0 0, v0x55c9b9140d40_0;  1 drivers
v0x55c9b9140b60_0 .net "b", 0 0, v0x55c9b9140e10_0;  1 drivers
v0x55c9b9140c20_0 .var "c", 0 0;
E_0x55c9b9131080 .event edge, v0x55c9b9140b60_0, v0x55c9b90fb030_0;
    .scope S_0x55c9b9130c40;
T_0 ;
    %wait E_0x55c9b9131080;
    %load/vec4 v0x55c9b90fb030_0;
    %load/vec4 v0x55c9b9140b60_0;
    %and;
    %store/vec4 v0x55c9b9140c20_0, 0, 1;
    %jmp T_0;
    .thread T_0, $push;
    .scope S_0x55c9b9130ac0;
T_1 ;
    %vpi_call 2 6 "$dumpfile", "andgate1.vcd" {0 0 0};
    %vpi_call 2 7 "$dumpvars" {0 0 0};
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x55c9b9140d40_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x55c9b9140e10_0, 0, 1;
    %delay 10, 0;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x55c9b9140d40_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x55c9b9140e10_0, 0, 1;
    %delay 10, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x55c9b9140d40_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x55c9b9140e10_0, 0, 1;
    %delay 10, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x55c9b9140d40_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x55c9b9140e10_0, 0, 1;
    %delay 10, 0;
    %vpi_call 2 20 "$finish" {0 0 0};
    %end;
    .thread T_1;
