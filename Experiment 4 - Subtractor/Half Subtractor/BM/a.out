#! /usr/bin/vvp
:ivl_version "11.0 (stable)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision + 0;
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/system.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_sys.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_textio.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2005_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/va_math.vpi";
S_0x5646442dd6f0 .scope module, "testbencha1" "testbencha1" 2 1;
 .timescale 0 0;
v0x5646442ef2a0_0 .var "a", 0 0;
v0x5646442ef360_0 .var "b", 0 0;
v0x5646442ef430_0 .net "borrow", 0 0, v0x5646442ef060_0;  1 drivers
v0x5646442ef530_0 .net "difference", 0 0, v0x5646442ef130_0;  1 drivers
S_0x5646442dd880 .scope module, "uut" "halfsubtractor" 2 4, 3 1 0, S_0x5646442dd6f0;
 .timescale 0 0;
    .port_info 0 /OUTPUT 1 "difference";
    .port_info 1 /OUTPUT 1 "borrow";
    .port_info 2 /INPUT 1 "a";
    .port_info 3 /INPUT 1 "b";
v0x5646442a5ba0_0 .net "a", 0 0, v0x5646442ef2a0_0;  1 drivers
v0x5646442eefa0_0 .net "b", 0 0, v0x5646442ef360_0;  1 drivers
v0x5646442ef060_0 .var "borrow", 0 0;
v0x5646442ef130_0 .var "difference", 0 0;
E_0x5646442a46e0 .event edge, v0x5646442eefa0_0, v0x5646442a5ba0_0;
    .scope S_0x5646442dd880;
T_0 ;
    %wait E_0x5646442a46e0;
    %load/vec4 v0x5646442a5ba0_0;
    %load/vec4 v0x5646442eefa0_0;
    %xor;
    %store/vec4 v0x5646442ef130_0, 0, 1;
    %load/vec4 v0x5646442a5ba0_0;
    %inv;
    %load/vec4 v0x5646442eefa0_0;
    %and;
    %store/vec4 v0x5646442ef060_0, 0, 1;
    %jmp T_0;
    .thread T_0, $push;
    .scope S_0x5646442dd6f0;
T_1 ;
    %vpi_call 2 6 "$dumpfile", "halfsubtractor.vcd" {0 0 0};
    %vpi_call 2 7 "$dumpvars" {0 0 0};
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5646442ef2a0_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5646442ef360_0, 0, 1;
    %delay 10, 0;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5646442ef2a0_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5646442ef360_0, 0, 1;
    %delay 10, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5646442ef2a0_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5646442ef360_0, 0, 1;
    %delay 10, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5646442ef2a0_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5646442ef360_0, 0, 1;
    %delay 10, 0;
    %vpi_call 2 20 "$finish" {0 0 0};
    %end;
    .thread T_1;
# The file index is used to find the file name in the following table.
:file_names 4;
    "N/A";
    "<interactive>";
    "testbencha1.v";
    "halfsubtractor.v";
